# YTSEO configuration — copy this file to .env and fill in your values
# Instructions: https://github.com/JohnEhresmann3D/YTSEO_PressStart#step-6

# Required for AI content generation — get yours free at github.com/settings/tokens
GITHUB_TOKEN=

# Optional: change the AI model (default: gpt-4o)
# Browse options at https://github.com/marketplace/models
GITHUB_MODEL=gpt-4o

# Optional: change transcription quality — tiny/base/small/medium/large (default: base)
WHISPER_MODEL=base

# Optional: override where uploads and audio files are stored
# YTSEO_DATA_DIR=./data
