# YTSEO configuration — copy this file to .env and fill in your values
# Instructions: https://github.com/JohnEhresmann3D/YTSEO_PressStart#step-6

# Required for AI content generation — get yours free at github.com/settings/tokens
GITHUB_TOKEN=

# Optional: change the AI model (default: gpt-4o)
# Browse options at https://github.com/marketplace/models
GITHUB_MODEL=gpt-4o

# Optional: change transcription quality — tiny/base/small/medium/large (default: base)
WHISPER_MODEL=base

# Optional: override where uploads and audio files are stored
# YTSEO_DATA_DIR=./data

# ─── Login gate ───────────────────────────────────────────────
# Single-user credential check at /login. Defaults shown below.
# Change BEFORE deploying anywhere reachable from the public internet.
YTSEO_ADMIN_USER=admin
YTSEO_ADMIN_PASSWORD=pressstart
# Long random string — without this, sessions reset on every restart.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
YTSEO_SESSION_SECRET=

# ─── Auto-Posting to Social Platforms ─────────────────────────
# Leave any block blank to skip that platform; the UI will show "no API keys"
# and the corresponding Connect button will be disabled.

# YouTube — Google Cloud Console → APIs & Services → Credentials → OAuth client (Web app)
# Authorized redirect URI: http://127.0.0.1:8000/api/auth/youtube/callback
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# X (Twitter) — developer.x.com → Project & App → User auth settings → OAuth 2.0
# Required scopes: tweet.read tweet.write users.read media.write offline.access
# Callback URL: http://127.0.0.1:8000/api/auth/x/callback
# Public client (PKCE only): leave X_CLIENT_SECRET blank
# Confidential client: set both
X_CLIENT_ID=
X_CLIENT_SECRET=
